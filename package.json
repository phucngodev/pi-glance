{
  "name": "pi-glance",
  "version": "0.2.1",
  "description": "A polished input surface extension for pi, with a rounded multiline editor and inline model/context/status glance.",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "extension",
    "input-surface",
    "statusline",
    "terminal",
    "tui"
  ],
  "type": "module",
  "license": "MIT",
  "author": "linys77",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LinYS77/pi-glance.git"
  },
  "homepage": "https://github.com/LinYS77/pi-glance#readme",
  "bugs": {
    "url": "https://github.com/LinYS77/pi-glance/issues"
  },
  "files": [
    "*.ts",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@types/node": "*",
    "typescript": "*"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "build:dev": "rm -rf .tmp-git-dev && tsc -p tsconfig.test.json",
    "test:git": "npm run build:dev --silent && node .tmp-git-dev/scripts/test-git.js && node .tmp-git-dev/scripts/test-git-refresher.js && node .tmp-git-dev/scripts/test-state-git.js",
    "debug:git": "npm run build:dev --silent && node .tmp-git-dev/scripts/debug-git.js",
    "pack:dry": "npm pack --dry-run"
  }
}
